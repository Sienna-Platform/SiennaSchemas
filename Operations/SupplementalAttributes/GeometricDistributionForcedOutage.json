{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GeometricDistributionForcedOutage",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer"
    },
    "mean_time_to_recovery": {
      "type": "number",
      "default": 0.0
    },
    "outage_transition_probability": {
      "type": "number",
      "default": 0.0
    },
    "monitored_components": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uuid"
      },
      "uniqueItems": true,
      "default": [],
      "description": "UUIDs of devices whose post-contingency state should be modeled when this outage occurs. Empty by default; semantics of an empty list are decided by the downstream consumer."
    }
  },
  "required": [
    "id"
  ]
}
