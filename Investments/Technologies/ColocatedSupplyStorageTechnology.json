{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": [
        "name",
        "available",
        "power_systems_type"
    ],
    "properties": {
        "name": {
            "type": "string"
        },
        "id": {
            "type": "integer"
        },
        "power_systems_type": {
            "type": "string"
        },
        "region": {
            "type": "array",
            "items": {
                "type": "integer"
            }
        },
        "financial_data": {
            "$ref": "../../Core/common.json#/definitions/TechnologyFinancialData"
        },
        "available": {
            "type": "boolean"
        },
        "capital_costs_solar": {
            "$ref": "../../Core/common.json#/definitions/ValueCurve"
        },
        "operation_costs_solar": {
            "$ref": "../../Core/common.json#/definitions/RenewableGenerationCost"
        },
        "capacity_limits_solar": {
            "$ref": "../../Core/common.json#/definitions/MinMax"
        },
        "lifetime_solar": {
            "type": "integer"
        },
        "capital_costs_wind": {
            "$ref": "../../Core/common.json#/definitions/ValueCurve"
        },
        "operation_costs_wind": {
            "$ref": "../../Core/common.json#/definitions/RenewableGenerationCost"
        },
        "capacity_limits_wind": {
            "$ref": "../../Core/common.json#/definitions/MinMax"
        },
        "lifetime_wind": {
            "type": "integer"
        },
        "capital_costs_energy": {
            "$ref": "../../Core/common.json#/definitions/ValueCurve"
        },
        "capital_costs_power": {
            "$ref": "../../Core/common.json#/definitions/ValueCurve"
        },
        "operation_costs_energy": {
            "$ref": "../../Core/common.json#/definitions/StorageCost"
        },
        "operation_costs_power": {
            "$ref": "../../Core/common.json#/definitions/StorageCost"
        },
        "capacity_power_limits": {
            "$ref": "../../Core/common.json#/definitions/MinMax"
        },
        "capacity_energy_limits": {
            "$ref": "../../Core/common.json#/definitions/MinMax"
        },
        "duration_limits": {
            "$ref": "../../Core/common.json#/definitions/MinMax"
        },
        "efficiency_storage": {
            "$ref": "../../Core/common.json#/definitions/InOut"
        },
        "losses_storage": {
            "type": "number",
            "default": "1.0"
        },
        "lifetime_storage": {
            "type": "integer",
            "default": "100"
        },
        "max_inverter_capacity": {
            "type": "number"
        },
        "min_inverter_capacity": {
            "type": "number"
        },
        "capital_costs_inverter": {
            "$ref": "../../Core/common.json#/definitions/ValueCurve"
        },
        "operation_costs_inverter": {
            "$ref": "../../Core/common.json#/definitions/ProductionVariableCostCurve"
        },
        "inverter_efficiency": {
            "type": "number"
        },
        "inverter_supply_ratio": {
            "type": "number"
        }
    }
}