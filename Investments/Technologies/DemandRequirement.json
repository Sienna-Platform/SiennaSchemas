{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": [
        "name",
        "available",
        "power_systems_type"
    ],
    "properties": {
        "name": {
            "type": "string"
        },
        "id": {
            "type": "integer"
        },
        "available": {
            "type": "boolean",
            "default": "true"
        },
        "power_systems_type": {
            "type": "string"
        },
        "conformity": {
            "type": "string",
            "default": "UNDEFINED"
        },
        "growth_rate": {
            "type": "number",
            "default": "0.0"
        },
        "new_demand_mw": {
            "type": "number",
            "default": "0.0"
        },
        "new_construction_year": {
            "type": "integer",
            "default": "2020"
        },
        "region": {
            "type": "array",
            "items": {
                "type": "integer"
            }
        },
        "value_of_lost_load": {
            "type": "number"
        },
        "unserved_demand_curve": {
            "$ref": "../../Core/common.json#/definitions/ValueCurve"
        }
    }
}