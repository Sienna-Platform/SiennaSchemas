      "description": "defines the storage technology used in an energy Storage system, based on the options in EIA form 923.",
      "enum": [
        "PTES",
        "LIB",
        "LAB",
        "FLWB",
        "SIB",
        "ZIB",
        "HGS",
        "LAES",
        "OTHER_CHEM",
        "OTHER_MECH",
        "OTHER_THERM"
      ],
      "title": "StorageTech",
      "type": "string"
    },
