    "RenewableGenerationCost": {
      "description": "Cost representation for renewable generation units",
      "properties": {
        "cost_type": {
          "const": "RENEWABLE",
          "type": "string",
          "default": "RENEWABLE"
        },
        "curtailment_cost": {
          "default": {
            "variable_cost_type": "COST",
            "value_curve": {
              "curve_type": "INPUT_OUTPUT",
              "function_data": {
                "function_type": "LINEAR",
                "constant_term": 0,
                "proportional_term": 0
              },
              "input_at_zero": 0
            },
            "vom_cost": {
              "curve_type": "INPUT_OUTPUT",
              "function_data": {
                "function_type": "LINEAR",
                "constant_term": 0,
                "proportional_term": 0
              },
              "input_at_zero": 0
            } 
          },
          "$ref": "#/definitions/CostCurve"
        },
        "variable": {
          "$ref": "#/definitions/CostCurve"
        },
        "fixed": {
          "type": "number",
          "default": 0.0
        }
      },
      "required": [
        "variable"
