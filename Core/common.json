      "type": "object",
      "minProperties": 1,
      "maxProperties": 1,
      "additionalProperties": {
        "oneOf": [
          {
            "type": "boolean"
          },
          {
            "type": "integer"
          },
          {
            "type": "string"
          }
        ]
      },
      "title": "Feature"
    },
