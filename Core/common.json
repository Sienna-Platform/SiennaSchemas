          "type": "number"
        },
        "hot": {
          "type": "number"
        },
        "warm": {
          "type": "number"
        }
      },
      "required": [
        "hot",
        "warm",
        "cold"
      ],
      "title": "StartUpStages",
      "type": "object"
    },
    "StorageCost": {
      "description": "Cost representation for storage units",
      "properties": {
        "cost_type": {
          "const": "STORAGE",
          "type": "string",
          "default": "STORAGE"
        },
        "charge_variable_cost": {
          "$ref": "#/definitions/CostCurve"
        },
        "discharge_variable_cost": {
          "$ref": "#/definitions/CostCurve"
        },
        "fixed": {
          "default": 0.0,
          "type": "number"
        },
        "shut_down": {
          "default": 0.0,
          "type": "number"
        },
        "start_up": {
          "default": 0.0,
          "oneOf": [
            {
              "type": "number"
            },
            {
              "properties": {
                "charge": {
                  "type": "number"
                },
                "discharge": {
                  "type": "number"
                }
              },
              "type": "object"
            }
          ]
        },
        "energy_shortage_cost": {
          "default": 0.0,
          "type": "number"
        },
        "energy_surplus_cost": {
          "default": 0.0,
          "type": "number"
        }
      },
      "required": [
        "fixed",
        "start_up",
        "shut_down"
      ],
      "title": "StorageCost",
      "type": "object"
    },
